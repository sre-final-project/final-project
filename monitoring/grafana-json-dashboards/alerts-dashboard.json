{
  "uid": "ecommerce-alerts",
  "title": "Ecommerce - Alerts & SRE",
  "tags": ["ecommerce", "alerts", "sre"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Firing Alerts",
      "type": "alertlist",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "options": {
        "alertName": "",
        "dashboardAlerts": false,
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": false, "error": false }
      }
    },
    {
      "id": 2,
      "title": "Service Uptime (last 24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "avg_over_time(up[24h]) * 100", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 95 },
            { "color": "green", "value": 99 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Service Down Events",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 7 },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0, "max": 1,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]},
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 30 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "title": "High CPU Alert Zone (>80%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "targets": [
        { "expr": "process_cpu_usage * 100", "legendFormat": "{{job}}", "refId": "A" },
        { "expr": "vector(80)", "legendFormat": "ALERT threshold (80%)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ALERT threshold (80%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Error Rate Alert Zone (>5%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 7 },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[1m])) / sum by (job) (rate(http_requests_total[1m])) * 100", "legendFormat": "{{job}} error%", "refId": "A" },
        { "expr": "vector(5)", "legendFormat": "ALERT threshold (5%)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ALERT threshold (5%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "SLO: Request Success Rate (target 99%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 7 },
      "targets": [
        { "expr": "(1 - sum by (job) (rate(http_requests_total{status=~\"5..\"}[5m])) / sum by (job) (rate(http_requests_total[5m]))) * 100", "legendFormat": "{{job}} success%", "refId": "A" },
        { "expr": "vector(99)", "legendFormat": "SLO target (99%)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 90, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 95 },
            { "color": "green", "value": 99 }
          ]},
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO target (99%)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } }
            ]
          }
        ]
      }
    }
  ]
}
